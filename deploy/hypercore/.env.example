# Copy to .env and fill in real values. NEVER commit .env.
# Generate strong values with: openssl rand -base64 32

# API image tag — CI overrides this per deploy via `export IMAGE_TAG=sha-xxxxxxx`.
# Leave unset locally to pull `:latest`.
IMAGE_TAG=latest

# Public hostname (point this DNS A record at your HyperCore IP)
API_DOMAIN=api.daugiavinhyen.com
CORS_ORIGIN=https://daugiavinhyen.com

# Postgres (on-VM)
POSTGRES_USER=daugia
POSTGRES_PASSWORD=replace_with_openssl_rand
POSTGRES_DB=daugia

# JWT signing key — keep stable; rotating invalidates all admin sessions
JWT_SECRET=replace_with_openssl_rand_base64_64

# Admin seed account (used by `cmd/seed`)
ADMIN_EMAIL=admin@daugiavinhyen.com
ADMIN_PASSWORD=replace_with_strong_password

# Object storage — Cloudflare R2 (S3-compatible, 10 GB free, $0 egress).
# HyperCore's Object Storage is 1 TB minimum and currently has no region available,
# so we use R2 here. The Go code (minio-go) works against R2 unchanged.
#
# 1. Cloudflare dashboard → R2 → Create bucket "daugia-articles"
# 2. R2 → Manage R2 API tokens → Create API token (Object Read & Write, scoped to the bucket)
# 3. Note the "S3 API" endpoint shown — format: <ACCOUNT_ID>.r2.cloudflarestorage.com
OBJECT_STORAGE_ENDPOINT=<account-id>.r2.cloudflarestorage.com
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_BUCKET=daugia-articles
