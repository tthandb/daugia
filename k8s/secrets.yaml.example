# DO NOT commit real secrets — use kubectl create secret instead:
# kubectl create secret generic realestate-secrets \
#   --from-literal=DATABASE_URL='postgres://postgres:YOUR_PASSWORD@postgres:5432/daugia?sslmode=disable' \
#   --from-literal=JWT_SECRET='YOUR_JWT_SECRET' \
#   --from-literal=MINIO_ACCESS_KEY='YOUR_MINIO_KEY' \
#   --from-literal=MINIO_SECRET_KEY='YOUR_MINIO_SECRET' \
#   --from-literal=ADMIN_EMAIL='admin@daugia.vn' \
#   --from-literal=ADMIN_PASSWORD='YOUR_ADMIN_PASSWORD' \
#   -n realestate

apiVersion: v1
kind: Secret
metadata:
  name: realestate-secrets
  namespace: realestate
type: Opaque
stringData:
  DATABASE_URL: "postgres://postgres:changeme@postgres:5432/daugia?sslmode=disable"
  JWT_SECRET: "change-this-to-a-random-64-char-string"
  MINIO_ACCESS_KEY: "minioadmin"
  MINIO_SECRET_KEY: "minioadmin"
  ADMIN_EMAIL: "admin@daugia.vn"
  ADMIN_PASSWORD: "changeme123"
